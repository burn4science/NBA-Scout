# PostgreSQL credentials — used by both the db container and the app containers.
# The DATABASE_URL is constructed from these in docker-compose.yml.
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# Password for the locked-down, non-owner application role (nba_app) that the
# migration creates. The app/embed services connect as this role so Row-Level
# Security is enforced against them. Use a different value than POSTGRES_PASSWORD.
APP_DB_PASSWORD=

# Connection URLs for running tooling LOCALLY (outside Docker), e.g. alembic and
# the test suite. Inside Docker these are derived in docker-compose.yml instead.
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}
MIGRATION_DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}
APP_DATABASE_URL=postgresql://nba_app:${APP_DB_PASSWORD}@localhost:5432/${POSTGRES_DB}

# Embedding endpoint — OpenAI-compatible. Model and dimension live in
# src/embed/config.toml; only the endpoint and key (environment-specific) are here.
#   Dev (host LM Studio):     http://localhost:1234/v1   (or host.docker.internal from a container)
#   Prod (Ollama Cloud):      https://ollama.com/v1
EMBEDDING_BASE_URL=http://localhost:1234/v1
# API key for the embedding endpoint. LM Studio ignores it (use any placeholder);
# Ollama Cloud requires a real key. Never commit the real value.
EMBEDDING_API_KEY=lm-studio

# Absolute path to the shared data directory (NFS/SMB mount or local path).
# All Docker volume sources are bound through this variable — no hardcoded paths allowed.
HOST_SHARED_DATA_DIR=
